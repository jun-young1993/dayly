<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- 알림 표시 권한 (Android 13 / API 33+에서 런타임 요청 필요) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- 정확한 알람 권한 (Android 12 / API 31+).
         이 권한이 없으면 zonedSchedule이 silently fail → 알림 미수신의 주원인. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>

    <!-- 재부팅 후 AlarmManager 복원 (flutter_local_notifications BootReceiver용) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <application
        android:label="dayly"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
    >
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- 홈화면 위젯 딥링크: dayly://detail/{id} / dayly://home -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="dayly"/>
            </intent-filter>
        </activity>
        <!-- ── 홈화면 위젯 Provider ── -->
        <receiver
            android:name=".DaylyAppWidget"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
                <action android:name="juny.dayly.MIDNIGHT_UPDATE"/>
                <!-- 타임존 변경 시 D-Day 즉시 재계산 -->
                <action android:name="android.intent.action.TIMEZONE_CHANGED"/>
            </intent-filter>
            <!-- Small 위젯 -->
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/dayly_widget_info_small"/>
        </receiver>

        <!-- Medium(4×2) 위젯 Provider -->
        <receiver
            android:name=".DaylyAppWidgetMedium"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
                <action android:name="juny.dayly.MIDNIGHT_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/dayly_widget_info_medium"/>
        </receiver>

        <!-- Large(4×4) 위젯 Provider -->
        <receiver
            android:name=".DaylyAppWidgetLarge"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
                <action android:name="juny.dayly.MIDNIGHT_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/dayly_widget_info_large"/>
        </receiver>

        <!-- StackView 컬렉션 위젯용 RemoteViewsService -->
        <service
            android:name=".DaylyWidgetRemoteViewsService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <!-- DaylyWidgetConfigActivity: 레거시. appwidget-provider에 android:configure 미설정이므로
             정상 플로우에서는 실행되지 않지만, 일부 런처(Samsung One UI 등)가
             APPWIDGET_CONFIGURE intent-filter를 감지해 리사이즈 시 자동 실행 → RESULT_CANCELED 반환
             → "Couldn't add widget" 에러 유발. manifest 등록 제거로 문제 해결. -->

        <!-- ── 딥링크: dayly://detail/{widgetId} ── -->
        <!-- MainActivity에 intent-filter 추가 -->

        <meta-data
                android:name="com.google.android.gms.ads.APPLICATION_ID"
                android:value="ca-app-pub-4656262305566191~8990935987"/>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
