<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- м•ҢлҰј н‘ңмӢң к¶Ңн•ң (Android 13 / API 33+м—җм„ң лҹ°нғҖмһ„ мҡ”мІӯ н•„мҡ”) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- м •нҷ•н•ң м•ҢлһҢ к¶Ңн•ң (Android 12 / API 31+).
         мқҙ к¶Ңн•ңмқҙ м—Ҷмңјл©ҙ zonedScheduleмқҙ silently fail вҶ’ м•ҢлҰј лҜёмҲҳмӢ мқҳ мЈјмӣҗмқё. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>

    <!-- мһ¬л¶ҖнҢ… нӣ„ AlarmManager ліөмӣҗ (flutter_local_notifications BootReceiverмҡ©) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <application
        android:label="dayly"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
    >
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- нҷҲнҷ”л©ҙ мң„м Ҝ л”Ҙл§ҒнҒ¬: dayly://detail/{id} / dayly://home -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="dayly"/>
            </intent-filter>
        </activity>
        <!-- в”Җв”Җ нҷҲнҷ”л©ҙ мң„м Ҝ Provider в”Җв”Җ -->
        <receiver
            android:name=".DaylyAppWidget"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
                <action android:name="juny.dayly.MIDNIGHT_UPDATE"/>
            </intent-filter>
            <!-- Small мң„м Ҝ -->
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/dayly_widget_info_small"/>
        </receiver>

        <!-- Medium мң„м ҜмқҖ лі„лҸ„ receiver м„ м–ё л¶Ҳн•„мҡ” вҖ” Provider н•ҳлӮҳк°Җ л‘җ л Ҳмқҙм•„мӣғ лӘЁл‘җ мІҳлҰ¬ -->

        <!-- StackView м»¬л үм…ҳ мң„м Ҝмҡ© RemoteViewsService -->
        <service
            android:name=".DaylyWidgetRemoteViewsService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <!-- DaylyWidgetConfigActivity: л Ҳкұ°мӢң. appwidget-providerм—җ android:configure лҜём„Өм •мқҙлҜҖлЎң
             м •мғҒ н”ҢлЎңмҡ°м—җм„ңлҠ” мӢӨн–үлҗҳм§Җ м•Ҡм§Җл§Ң, мқјл¶Җ лҹ°мІҳ(Samsung One UI л“ұ)к°Җ
             APPWIDGET_CONFIGURE intent-filterлҘј к°җм§Җн•ҙ лҰ¬мӮ¬мқҙмҰҲ мӢң мһҗлҸҷ мӢӨн–ү вҶ’ RESULT_CANCELED л°ҳнҷҳ
             вҶ’ "Couldn't add widget" м—җлҹ¬ мң л°ң. manifest л“ұлЎқ м ңкұ°лЎң л¬ём ң н•ҙкІ°. -->

        <!-- в”Җв”Җ л”Ҙл§ҒнҒ¬: dayly://detail/{widgetId} в”Җв”Җ -->
        <!-- MainActivityм—җ intent-filter м¶”к°Җ -->

        <meta-data
                android:name="com.google.android.gms.ads.APPLICATION_ID"
                android:value="ca-app-pub-4656262305566191~8990935987"/>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
