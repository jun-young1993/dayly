<?xml version="1.0" encoding="utf-8"?>
<!-- 위젯 배경: paper 테마 — 따뜻한 종이 톤 + 상단 하이라이트 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 기본 그라데이션 배경 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#F9F4EC"
                android:endColor="#F2EBE0" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- 상단 하이라이트 (10% 흰색 → 투명, 종이 광택감) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#1AFFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>

</layer-list>
