<?xml version="1.0" encoding="utf-8"?>
<!-- 위젯 배경: lavender 테마 — 부드러운 라벤더 톤 + 상단 하이라이트 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#F4EFF9"
                android:endColor="#EDE6F5" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- 상단 하이라이트 (11% 흰색 → 투명) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#1CFFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>

</layer-list>
