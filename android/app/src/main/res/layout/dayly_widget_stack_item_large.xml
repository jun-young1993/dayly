<?xml version="1.0" encoding="utf-8"?>
<!--
  StackView 아이템 — Large (4x4)
  Medium 대비 더 넉넉한 수직 공간을 활용해 큰 카운트다운과 긴 문구를 표시한다.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dayly_widget_bg">

    <!-- 배경 이미지 (사진 설정 시에만 VISIBLE) -->
    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="" />

    <!-- 텍스트 가독성 보호 오버레이 (사진 설정 시에만 VISIBLE): 하단 그라디언트 스크림 -->
    <ImageView
        android:id="@+id/widget_bg_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_bg_gradient_scrim_bottom"
        android:visibility="gone"
        android:contentDescription="" />

    <!-- 기존 콘텐츠 (background 속성 제거 — widget_container(FrameLayout)에 Kotlin이 동적 적용) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 상단 콘텐츠 영역 (남은 공간을 채움) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="bottom">

            <!-- 날짜 레이블 (예: 2026.06.01) -->
            <TextView
                android:id="@+id/widget_date_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#7090B0"
                android:letterSpacing="0.08"
                android:maxLines="1"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="6" />

            <!-- D-Day 카운트다운 숫자 (핵심) -->
            <TextView
                android:id="@+id/widget_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="D-?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#F4F6FA"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="8" />

            <!-- 진행 바: 현재 위치 / 전체 개수 (테마별 색상은 Kotlin에서 동적 적용) -->
            <FrameLayout
                android:id="@+id/widget_progress_container"
                android:layout_width="96dp"
                android:layout_height="3dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:clipChildren="true">

                <ImageView
                    android:id="@+id/widget_progress_track"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:contentDescription="" />

                <ImageView
                    android:id="@+id/widget_progress_fill"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:contentDescription="" />

            </FrameLayout>

            <!-- 감성 문구 -->
            <TextView
                android:id="@+id/widget_sentence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="16sp"
                android:textColor="#7090B0"
                android:gravity="start"
                android:maxLines="3"
                android:ellipsize="end"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="6" />

        </LinearLayout>

        <!-- 하단 바: 페이지 인디케이터(좌) + dayly 워터마크(우) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <!-- 페이지 인디케이터: < 1/4 > (복수 위젯 시에만 표시) -->
            <TextView
                android:id="@+id/widget_page_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text=""
                android:textSize="10sp"
                android:textColor="#4060A0"
                android:fontFamily="monospace"
                android:visibility="gone" />

            <!-- dayly 워터마크 -->
            <TextView
                android:id="@+id/widget_watermark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="dayly"
                android:textSize="10sp"
                android:textColor="#2A3A5A"
                android:fontFamily="monospace" />

        </RelativeLayout>

    </LinearLayout>

</FrameLayout>
