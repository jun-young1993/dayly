<?xml version="1.0" encoding="utf-8"?>
<!--
  StackView 아이템 — Large (4x4)
  Medium 대비 더 넉넉한 수직 공간을 활용해 큰 카운트다운과 긴 문구를 표시한다.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/dayly_widget_bg">

    <!-- 상단 콘텐츠 영역 (남은 공간을 채움) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="bottom">

        <!-- 날짜 레이블 (예: 2026.06.01) -->
        <TextView
            android:id="@+id/widget_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#7090B0"
            android:letterSpacing="0.08"
            android:maxLines="1" />

        <!-- D-Day 카운트다운 숫자 (핵심) -->
        <TextView
            android:id="@+id/widget_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="D-?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F4F6FA"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- 진행 바: 현재 위치 / 전체 개수 -->
        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="96dp"
            android:layout_height="3dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:max="100"
            android:progress="100"
            android:indeterminate="false"
            android:progressTint="#4060A0"
            android:progressBackgroundTint="#1A2A4A" />

        <!-- 감성 문구 -->
        <TextView
            android:id="@+id/widget_sentence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textColor="#7090B0"
            android:gravity="start"
            android:maxLines="3"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- 하단 바: 페이지 인디케이터(좌) + dayly 워터마크(우) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <!-- 페이지 인디케이터: < 1/4 > (복수 위젯 시에만 표시) -->
        <TextView
            android:id="@+id/widget_page_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text=""
            android:textSize="10sp"
            android:textColor="#4060A0"
            android:fontFamily="monospace"
            android:visibility="gone" />

        <!-- dayly 워터마크 -->
        <TextView
            android:id="@+id/widget_watermark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="dayly"
            android:textSize="10sp"
            android:textColor="#2A3A5A"
            android:fontFamily="monospace" />

    </RelativeLayout>

</LinearLayout>
