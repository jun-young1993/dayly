<?xml version="1.0" encoding="utf-8"?>
<!--
  StackView 아이템 — Medium (4x2)
  iOS와 동일하게 좌측 정렬, 페이지 인디케이터(<1/4>), dayly 워터마크를 포함한다.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/dayly_widget_bg">

    <!-- 상단 콘텐츠 영역 (남은 공간을 채움) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="top">

        <!-- 날짜 레이블 (예: 2026.06.01) -->
        <TextView
            android:id="@+id/widget_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="#7090B0"
            android:letterSpacing="0.08"
            android:maxLines="1" />

        <!-- D-Day 카운트다운 숫자 (핵심) -->
        <TextView
            android:id="@+id/widget_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="D-?"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#F4F6FA"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- 진행 바: 현재 위치 / 전체 개수 (테마별 색상은 Kotlin에서 동적 적용) -->
        <FrameLayout
            android:id="@+id/widget_progress_container"
            android:layout_width="72dp"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:clipChildren="true">

            <View
                android:id="@+id/widget_progress_track"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <View
                android:id="@+id/widget_progress_fill"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <!-- 감성 문구 -->
        <TextView
            android:id="@+id/widget_sentence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#7090B0"
            android:gravity="start"
            android:maxLines="2"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- 하단 바: 페이지 인디케이터(좌) + dayly 워터마크(우) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 페이지 인디케이터: < 1/4 > (복수 위젯 시에만 표시) -->
        <TextView
            android:id="@+id/widget_page_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text=""
            android:textSize="9sp"
            android:textColor="#4060A0"
            android:fontFamily="monospace"
            android:visibility="gone" />

        <!-- dayly 워터마크 -->
        <TextView
            android:id="@+id/widget_watermark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="dayly"
            android:textSize="9sp"
            android:textColor="#2A3A5A"
            android:fontFamily="monospace" />

    </RelativeLayout>

</LinearLayout>
