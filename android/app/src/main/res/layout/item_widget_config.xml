<?xml version="1.0" encoding="utf-8"?>
<!--
  위젯 구성 화면의 D-Day 선택 카드 아이템.
  반투명 흰색 배경 카드 스타일.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/config_item_bg"
    android:layout_marginBottom="10dp"
    android:padding="16dp"
    android:gravity="center_vertical">

    <!-- 테마 색상 바 (좌측 2dp) -->
    <View
        android:id="@+id/config_item_theme_bar"
        android:layout_width="3dp"
        android:layout_height="40dp"
        android:layout_marginEnd="14dp" />

    <!-- 텍스트 정보 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/config_item_sentence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F4F6FA"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/config_item_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="#7090B0"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- 우측 화살표 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textColor="#4060A0"
        android:textSize="20sp"
        android:layout_marginStart="8dp" />

</LinearLayout>
