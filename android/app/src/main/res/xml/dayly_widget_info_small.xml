<?xml version="1.0" encoding="utf-8"?>
<!--
  AppWidgetProviderInfo — Small (2×2)
  minWidth/minHeight: 110dp = 2셀 기준 최솟값
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:targetCellWidth="2"
    android:targetCellHeight="2"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/dayly_widget_small"
    android:previewLayout="@layout/dayly_widget_stack_item_small"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/dayly_widget_description" />
